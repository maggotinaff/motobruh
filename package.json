{
  "name": "motobro-bot",
  "version": "1.0.0",
  "private": true,
  "description": "Telegram-бот для мото-группы: кто катается и кто рядом",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.10",
    "@types/node-cron": "^3.0.11",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "node-cron": "^3.0.3",
    "pino": "^9.6.0",
    "prisma": "^6.5.0",
    "telegraf": "^4.16.3",
    "typescript": "^5.8.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.3",
    "vitest": "^3.0.9"
  }
}
