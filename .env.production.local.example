# Скопируй в .env.production.local (файл в .gitignore) и вставь строку подключения
# из Render Dashboard → твоя Postgres → Connect → External Database URL (или Internal).
# Используется только локально для: npm run prisma:deploy:prod
#
# Не коммить .env.production.local.

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
